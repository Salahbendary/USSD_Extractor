# ─────────────────────────────────────────────────────────────
# USSD KPI Extractor  —  Environment Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# ── GitHub Integration ─────────────────────────────────────
# Create a Personal Access Token at:
#   https://github.com/settings/tokens/new
#   Required scopes: repo (full)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your GitHub repository  (format: username/repo-name)
GITHUB_REPO=your-username/your-repo-name

# Path to the CSV file inside the repo
GITHUB_CSV_PATH=data/kpi_results.csv

# Branch to push/pull from
GITHUB_BRANCH=main

# ── PaddleOCR (optional) ───────────────────────────────────
# Path to your offline model folder (created by setup_offline_models.py)
# Leave blank to use PaddleOCR default cache (~/.paddleocr/)
PADDLE_MODEL_DIR=./paddle_models

# ─────────────────────────────────────────────────────────────
# NOTES:
#   - If GITHUB_TOKEN or GITHUB_REPO is empty, GitHub sync is
#     disabled but the app still works fully locally.
#   - If PaddleOCR is not installed, Tesseract is used automatically.
# ─────────────────────────────────────────────────────────────
